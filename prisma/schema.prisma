generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String       @id @default(cuid())
  walletAddress    String       @unique @map("wallet_address")
  username         String?      @unique
  sinScore         Int          @default(0) @map("sin_score")
  totalConfessions Int          @default(0) @map("total_confessions")
  totalDonated     Float        @default(0) @map("total_donated")
  donationCount    Int          @default(0) @map("donation_count")
  totalEarned      Float        @default(0) @map("total_earned")
  earnedCount      Int          @default(0) @map("earned_count")
  baptizeStreak    Int          @default(0) @map("baptize_streak")
  lastBaptizeDate  DateTime?    @map("last_baptize_date")
  streakMultiplier Float        @default(1.0) @map("streak_multiplier")
  createdAt        DateTime     @default(now()) @map("created_at")

  confessions      Confession[]
  comments         Comment[]
  likes            Like[]
  chatMessages     ChatMessage[]
  donations        Donation[]
  daresGiven       Dare[]       @relation("daresGiven")
  daresReceived    Dare[]       @relation("daresReceived")

  @@map("users")
}

model Confession {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  confessionText String    @map("confession_text")
  sinCategory    String    @map("sin_category")
  sinLevel       String    @map("sin_level")
  aiResponse     String    @map("ai_response")
  penance        String
  likesCount     Int       @default(0) @map("likes_count")
  commentsCount  Int       @default(0) @map("comments_count")
  totalDonated   Float     @default(0) @map("total_donated")
  donationCount  Int       @default(0) @map("donation_count")
  txHash         String?   @map("tx_hash")
  onChainId      Int?      @map("on_chain_id")
  chainStatus    String    @default("pending") @map("chain_status")
  createdAt      DateTime  @default(now()) @map("created_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments       Comment[]
  likes          Like[]
  donations      Donation[]
  dares          Dare[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("confessions")
}

model Donation {
  id             String     @id @default(cuid())
  confessionId   String     @map("confession_id")
  userId         String     @map("user_id")
  amount         Float
  txHash         String     @map("tx_hash")
  createdAt      DateTime   @default(now()) @map("created_at")

  confession     Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([confessionId])
  @@index([userId])
  @@index([amount(sort: Desc)])
  @@map("donations")
}

model Comment {
  id           String     @id @default(cuid())
  confessionId String     @map("confession_id")
  userId       String     @map("user_id")
  commentText  String     @map("comment_text")
  createdAt    DateTime   @default(now()) @map("created_at")

  confession   Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([confessionId])
  @@map("comments")
}

model Like {
  id           String     @id @default(cuid())
  confessionId String     @map("confession_id")
  userId       String     @map("user_id")
  createdAt    DateTime   @default(now()) @map("created_at")

  confession   Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([confessionId, userId])
  @@index([confessionId])
  @@index([userId])
  @@map("likes")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

// ===== Dare System =====
model Dare {
  id                  String     @id @default(cuid())
  confessionId        String     @map("confession_id")
  fromUserId          String     @map("from_user_id")
  toUserId            String     @map("to_user_id")
  dareText            String     @map("dare_text")
  amount              Float
  txHash              String     @map("tx_hash")
  status              String     @default("pending")     // pending | accepted | declined | expired
  acceptedAt          DateTime?  @map("accepted_at")
  resultConfessionId  String?    @map("result_confession_id")
  createdAt           DateTime   @default(now()) @map("created_at")
  expiresAt           DateTime   @map("expires_at")

  confession          Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)
  fromUser            User       @relation("daresGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser              User       @relation("daresReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, status])
  @@index([confessionId])
  @@map("dares")
}

// ===== Weekly Baptism Pool =====
model BaptismPool {
  id          String       @id @default(cuid())
  weekStart   DateTime     @map("week_start")
  weekEnd     DateTime     @map("week_end")
  totalPool   Float        @default(0) @map("total_pool")
  distributed Boolean      @default(false)
  createdAt   DateTime     @default(now()) @map("created_at")

  payouts     PoolPayout[]

  @@unique([weekStart])
  @@map("baptism_pools")
}

model PoolPayout {
  id        String      @id @default(cuid())
  poolId    String      @map("pool_id")
  userId    String      @map("user_id")
  rank      Int
  amount    Float
  txHash    String?     @map("tx_hash")
  createdAt DateTime    @default(now()) @map("created_at")

  pool      BaptismPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId])
  @@index([userId])
  @@map("pool_payouts")
}
